{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/opds/index.js"
    },
    {
      "source": "/api/opds",
      "destination": "/api/opds/index.js"
    },
    {
      "source": "/api/opds/search.xml",
      "destination": "/api/opds/search.xml.js"
    }
  ]
}
